{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist/server",
    "rootDir": "src",
    "lib": ["ES2023"],
    "types": ["node"],
    "allowJs": true
  },
  "include": ["src/server/**/*", "src/lib/**/*", "src/utils/**/*"],
  "exclude": ["node_modules"]
}
