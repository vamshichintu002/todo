{
  "version": 2,
  "builds": [
    {
      "src": "src/server/api.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/server/api.ts"
    }
  ],
  "functions": {
    "src/server/api.ts": {
      "memory": 1024,
      "maxDuration": 10
    }
  }
}
